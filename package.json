{
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "node scripts/dev-manager.mjs start",
    "dev:start": "node scripts/dev-manager.mjs start",
    "dev:stop": "node scripts/dev-manager.mjs stop",
    "dev:restart": "node scripts/dev-manager.mjs restart",
    "dev:status": "node scripts/dev-manager.mjs status",
    "dev:env": "node scripts/dev-manager.mjs env",
    "web:dev": "npm --workspace apps/web run dev",
    "web:build": "npm --workspace apps/web run build",
    "web:test": "npm --workspace apps/web run test",
    "web:e2e": "npm --workspace apps/web run test:e2e",
    "web:typecheck": "npm --workspace apps/web run typecheck"
  },
  "devDependencies": {
    "shadcn": "^4.6.0",
    "shadcn-vue": "^2.3.0"
  }
}
