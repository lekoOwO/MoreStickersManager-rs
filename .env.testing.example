# MSM isolated testing environment
MSM_BIND_ADDR=127.0.0.1:3010
MSM_DATABASE_URL=sqlite:data/test/msm.sqlite3
MSM_ASSET_DIR=data/test/assets
MSM_WEB_DIST_DIR=apps/web/dist
MSM_FFMPEG_PATH=ffmpeg
MSM_FFPROBE_PATH=ffprobe
MSM_PREPARED_MEDIA_DIR=data/test/prepared-media
MSM_EXPORT_WORKER_ENABLED=false
MSM_EXPORT_WORKER_POLL_INTERVAL_MS=1000
MSM_EXPORT_RETRY_BACKOFF_MS=1000
MSM_DEV_BOOTSTRAP_ENABLED=false
MSM_DEV_TENANT_ID=tenant_1
MSM_DEV_TENANT_NAME=MSM Testing
MSM_DEV_USER_ID=user_1
MSM_DEV_USER_EMAIL=test@msm.local
MSM_DEV_USER_DISPLAY_NAME=MSM Test User
MSM_DEV_USER_PASSWORD=test-password
MSM_BOOTSTRAP_TENANT_ID=tenant_1
MSM_BOOTSTRAP_TENANT_NAME=MSM Testing
MSM_BOOTSTRAP_ADMIN_USER_ID=user_1
MSM_BOOTSTRAP_ADMIN_EMAIL=test@msm.local
MSM_BOOTSTRAP_ADMIN_DISPLAY_NAME=MSM Test User
MSM_BOOTSTRAP_ADMIN_PASSWORD=test-password
MSM_DEV_PAT_ID_PREFIX=test-web
MSM_DEV_PAT_NAME=Testing Web UI
MSM_DEV_PAT_SCOPES=pack.create pack.read pack.update pack.delete pack.manage_access asset.read subscription.create subscription.read subscription.update subscription.delete subscription.manage_access provider.import export.read export.run export.target.manage import.run pat.manage
MSM_DEV_SAMPLE_PACK_ENABLED=false

VITE_MSM_API_BASE_URL=http://127.0.0.1:3010
VITE_MSM_TENANT_ID=tenant_1
VITE_MSM_USER_ID=user_1
# VITE_MSM_PAT is written to .env.local by scripts/dev-manager.mjs when bootstrap is enabled.
