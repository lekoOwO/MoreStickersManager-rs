# MSM development environment
MSM_BIND_ADDR=127.0.0.1:3000
MSM_DATABASE_URL=sqlite:data/dev/msm.sqlite3
MSM_ASSET_DIR=data/dev/assets
MSM_WEB_DIST_DIR=apps/web/dist
MSM_FFMPEG_PATH=ffmpeg
MSM_FFPROBE_PATH=ffprobe
MSM_PREPARED_MEDIA_DIR=data/dev/prepared-media
MSM_EXPORT_WORKER_ENABLED=false
MSM_EXPORT_WORKER_POLL_INTERVAL_MS=5000
MSM_EXPORT_RETRY_BACKOFF_MS=60000
MSM_DEV_BOOTSTRAP_ENABLED=true
MSM_DEV_TENANT_ID=tenant_1
MSM_DEV_TENANT_NAME=MSM Development
MSM_DEV_USER_ID=user_1
MSM_DEV_USER_EMAIL=dev@msm.local
MSM_DEV_USER_DISPLAY_NAME=MSM Developer
MSM_DEV_USER_PASSWORD=dev-password
MSM_DEV_PAT_ID_PREFIX=dev-web
MSM_DEV_PAT_NAME=Development Web UI
MSM_DEV_PAT_SCOPES=pack.create pack.read pack.update pack.delete pack.manage_access asset.read subscription.create subscription.read subscription.update subscription.delete subscription.manage_access provider.import export.read export.run export.target.manage import.run pat.manage
MSM_DEV_SAMPLE_PACK_ENABLED=true

VITE_MSM_API_BASE_URL=http://127.0.0.1:3000
VITE_MSM_USER_ID=user_1
# VITE_MSM_PAT is written to .env.local by scripts/dev-manager.mjs when bootstrap is enabled.
