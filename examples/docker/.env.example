# Copy to examples/docker/.env and edit before starting Docker Compose.

COMPOSE_PROJECT_NAME=msm

# MSM public URL seen by browsers and Authentik.
# For local testing this can be http://localhost:3000.
# For production put the HTTPS URL behind your reverse proxy, e.g. https://stickers.example.com.
MSM_EXTERNAL_URL=http://localhost:3000
MSM_HTTP_PORT=3000

# Optional CDN/public asset URL. Leave blank to let MSM serve local /assets URLs.
# If using Cloudflare/CDN, set this to the externally reachable asset base URL.
MSM_PUBLIC_ASSET_URL=
MSM_PUBLIC_ASSET_BASE_URL=http://localhost:3000

# PostgreSQL used by MSM.
POSTGRES_DB=msm
POSTGRES_USER=msm
POSTGRES_PASSWORD=change-me-use-a-long-random-value

# Optional: pull a prebuilt image instead of building from this checkout.
# MSM_IMAGE=ghcr.io/lekoowo/morestickersmanager-rs:latest

# Workers. Keep disabled until ffmpeg/ffprobe are available in the image/host and you want background jobs.
MSM_EXPORT_WORKER_ENABLED=false
MSM_PROVIDER_IMPORT_WORKER_ENABLED=false

# Optional Telegram export target bootstrap JSON.
# Keep secrets out of Git; prefer configuring targets through the Web UI or secret manager.
MSM_BOOTSTRAP_EXPORT_TARGETS_JSON=

# First-start local admin bootstrap. On an empty database, msm-app creates this
# tenant and admin user, then prints the admin password in the
# bootstrap_admin_created console/log event. Leave MSM_BOOTSTRAP_ADMIN_PASSWORD
# blank to generate a random password.
MSM_BOOTSTRAP_TENANT_ID=default
MSM_BOOTSTRAP_TENANT_NAME=Default workspace
MSM_BOOTSTRAP_ADMIN_USER_ID=admin
MSM_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
MSM_BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin
MSM_BOOTSTRAP_ADMIN_PASSWORD=

# Authentik OIDC settings. msm-app stores OIDC providers in the database; these
# values are setup inputs for README.md / docs, not standalone runtime switches.

MSM_OIDC_PROVIDER_ID=authentik
MSM_OIDC_DISPLAY_NAME=Authentik
# Authentik provider issuer examples:
# - https://auth.example.com/application/o/msm/
# - http://localhost:9000/application/o/msm/
MSM_OIDC_ISSUER_URL=https://auth.example.com/application/o/msm/
MSM_OIDC_CLIENT_ID=replace-with-authentik-client-id
MSM_OIDC_CLIENT_SECRET=replace-with-authentik-client-secret
MSM_OIDC_SCOPES=openid email profile
# true lets first-time SSO users be created/linked by MSM when Authentik returns valid claims.
MSM_OIDC_ALLOW_REGISTRATION=true
